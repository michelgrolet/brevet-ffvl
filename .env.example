# Copy to .env and adjust.  (.env is gitignored — never commit your key.)

# Which data source the server uses: mock | ffvl | scrape
DATA_SOURCE=mock

# Required only when DATA_SOURCE=ffvl.
# Request a free key from informatique@ffvl.fr
FFVL_API_KEY=

# Optional: override the page the scraper reads the balise list from.
# SCRAPE_INDEX_URL=https://www.balisemeteo.com/

# Optional tuning
PORT=3000
CACHE_TTL_MS=60000

# ----------------------------------------------------------------------------
# Live flight tracking ("notify someone when I fly on XCTrack")
# ----------------------------------------------------------------------------
# Point XCTrack's livetracking server at this app (LiveTrack24 protocol). It
# receives your position, shows it on a public /live page, and sends a WhatsApp
# message with the live link when you take off / land. See README §3.

# Name shown on the live page / in messages if XCTrack doesn't send a glider name.
PILOT_NAME=Michel

# Absolute base URL of THIS server, used to build the shareable live link.
# Auto-detected from the request if left blank; set it when behind a proxy.
# PUBLIC_BASE_URL=https://your-host.example.com

# Recommended: Telegram group. You create a bot (@BotFather) and a group, add
# the bot + the people you want; EVERYONE in the group gets the alert and you
# set it all up yourself (no per-person key). See README §3.
# TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-1001234567890        # comma-separated for several chats

# Alt: free WhatsApp push via CallMeBot (no groups; each recipient must opt in
# once by messaging the CallMeBot number for an apikey). Format "phone:apikey".
# WHATSAPP_RECIPIENTS=33612345678:123456,33698765432:654321

# Optional extra channels (any combination):
# NTFY_TOPIC=michel-vols-xyz        # free push, anyone subscribed sees it
# NTFY_SERVER=https://ntfy.sh
# NOTIFY_WEBHOOK_URL=https://...     # generic JSON POST

# Takeoff/landing tuning
# TAKEOFF_SPEED_KMH=8     # ground speed that counts as "airborne"
# NOTIFY_ON_START=0       # 1 = notify the instant tracking starts (no movement check)
# LANDING_TIMEOUT_MIN=5   # treat as landed after this long with no new fix
